---
import { siteConfig } from "../config";
const hasCTA = siteConfig.cta;
const wa = `https://wa.me/${siteConfig.cta.whatsappNumber.replace(/\D/g, '')}`;
---

{hasCTA && (
  <section id="contact" class="relative py-20 lg:py-28 px-6 lg:px-8 overflow-hidden" style={`background: linear-gradient(180deg, ${siteConfig.colors.primaryDark} 0%, ${siteConfig.colors.surface} 40%, ${siteConfig.colors.primaryDark} 100%)`}>
    <!-- Glow orb decoration -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full opacity-[0.04]" style={`background: radial-gradient(circle, ${siteConfig.colors.accent}, transparent 70%)`}></div>

    <div class="relative max-w-2xl mx-auto text-center">
      <div class="reveal">
        <div class="bar-shimmer h-1 w-12 mx-auto rounded-full mb-8"></div>

        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight" style="color: #f1f5f9">
          ¿Listo/a para ordenar<br>
          <span style={`color: ${siteConfig.colors.accent}`}>tus finanzas?</span>
        </h2>

        <p class="mt-6 text-base sm:text-lg leading-relaxed max-w-lg mx-auto" style="color: #94a3b8">
          Si lideras un negocio y quieres dejar de vivir con presión económica — por ti y por las personas que dependen de ti — agenda una sesión estratégica conmigo.
        </p>

        <p class="mt-4 text-base leading-relaxed max-w-lg mx-auto" style="color: #cbd5e1">
          Un espacio claro, sin juicio y adaptado a tu realidad, donde veremos cómo estructurar tu empresa y tu dinero de forma sostenible.
        </p>

        <!-- Trust badges -->
        <div class="flex flex-wrap justify-center gap-3 mt-8 mb-10">
          {["30 min gratis", "Sin compromiso", "100% online"].map((item) => (
            <span class="px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider border" style={`border-color: ${siteConfig.colors.accent}25; color: ${siteConfig.colors.accent}; background-color: ${siteConfig.colors.accent}08`}>
              {item}
            </span>
          ))}
        </div>

        <a
          href={wa}
          target="_blank"
          rel="noopener noreferrer"
          class="cta-main-btn btn-hover inline-flex items-center gap-3 px-10 py-5 rounded-full text-lg font-bold shadow-2xl"
          style={`background: linear-gradient(135deg, ${siteConfig.colors.accent}, #e6c412); color: ${siteConfig.colors.primaryDark}`}
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Agenda aquí tu sesión
        </a>
      </div>
    </div>
  </section>
)}

<style>
  .cta-main-btn {
    animation: ctaGlow 2s ease-in-out infinite;
  }
  @keyframes ctaGlow {
    0%, 100% { box-shadow: 0 8px 30px rgba(247, 215, 20, 0.3); }
    50% { box-shadow: 0 16px 60px rgba(247, 215, 20, 0.5); }
  }
</style>
