---
import { siteConfig } from "../config";
---

<section id="programa" class="py-16 lg:py-24 px-6 lg:px-8" style={`background-color: ${siteConfig.colors.surface}`}>
  <div class="max-w-4xl mx-auto">

    <!-- Hero del programa -->
    <div class="reveal text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight" style="color: #f1f5f9">
        Ordena tu empresa. Ordena tu dinero. Ordena tus decisiones.
      </h2>
      <div class="mt-4 h-0.5 w-24 mx-auto bar-shimmer rounded-full"></div>
      <p class="mt-6 text-base sm:text-lg leading-relaxed max-w-2xl mx-auto" style="color: #94a3b8">
        Si tienes una MYPE y trabajas mucho, pero no sientes tranquilidad financiera, esto es para ti.
      </p>
    </div>

    <!-- Realidad -->
    <div class="reveal mb-12">
      <div class="space-y-2 text-center">
        <p class="text-base sm:text-lg" style="color: #cbd5e1">Vender no es lo mismo que ganar.</p>
        <p class="text-base sm:text-lg" style="color: #cbd5e1">Facturar no es lo mismo que tener caja.</p>
        <p class="text-base sm:text-lg" style="color: #cbd5e1">Crecer sin estructura puede desordenarlo todo.</p>
      </div>
    </div>

    <!-- El problema -->
    <div class="reveal mb-12">
      <h3 class="text-2xl sm:text-3xl font-bold text-center mb-6" style="color: #f1f5f9">
        El problema que casi nadie aborda
      </h3>
      <p class="text-base sm:text-lg leading-relaxed text-center mb-6" style="color: #94a3b8">
        La mayoría de programas trabajan solo una parte:
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-6">
        <div class="flex items-center gap-3 justify-center">
          <span style={`color: ${siteConfig.colors.accent}`}>&#x25B8;</span>
          <span class="text-base" style="color: #cbd5e1">O el negocio</span>
        </div>
        <div class="flex items-center gap-3 justify-center">
          <span style={`color: ${siteConfig.colors.accent}`}>&#x25B8;</span>
          <span class="text-base" style="color: #cbd5e1">O las finanzas personales</span>
        </div>
      </div>
      <div class="text-center space-y-2" style="color: #94a3b8">
        <p class="text-base sm:text-lg">Pero tú eres ambos.</p>
        <p class="text-sm leading-relaxed mt-4">
          Si mejoras la empresa pero sigues retirando dinero sin orden,<br>
          si creces pero no sabes cuánto capital necesitas,<br>
          el desorden vuelve.
        </p>
      </div>
      <div class="mt-8 text-center space-y-2">
        <p class="text-base font-medium" style="color: #cbd5e1">Mi enfoque es simple:</p>
        <p class="text-base" style={`color: ${siteConfig.colors.accent}`}>&#x1F449; Ordenamos la empresa.</p>
        <p class="text-base" style={`color: ${siteConfig.colors.accent}`}>&#x1F449; Ordenamos al dueño/a.</p>
        <p class="text-base font-semibold mt-2" style="color: #f1f5f9">Eso es estratégico.</p>
      </div>
    </div>

    <!-- Programa -->
    <div class="reveal mb-12">
      <h3 class="text-2xl sm:text-3xl font-bold text-center mb-8" style="color: #f1f5f9">
        Programa Integral CFO + Coach para MYPES
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- CFO Sessions -->
        <div class="p-6 rounded-xl border" style={`background-color: ${siteConfig.colors.primary}; border-color: ${siteConfig.colors.primaryLight}`}>
          <h4 class="text-lg font-bold mb-4" style={`color: ${siteConfig.colors.accent}`}>3 sesiones como CFO</h4>
          <ul class="space-y-3">
            <li class="flex items-start">
              <span class="inline-block w-1.5 h-1.5 rounded-full mt-2 mr-3 flex-shrink-0" style={`background-color: ${siteConfig.colors.accent}`}></span>
              <span class="text-sm" style="color: #94a3b8">Flujo de caja proyectado</span>
            </li>
            <li class="flex items-start">
              <span class="inline-block w-1.5 h-1.5 rounded-full mt-2 mr-3 flex-shrink-0" style={`background-color: ${siteConfig.colors.accent}`}></span>
              <span class="text-sm" style="color: #94a3b8">Capital de trabajo real</span>
            </li>
            <li class="flex items-start">
              <span class="inline-block w-1.5 h-1.5 rounded-full mt-2 mr-3 flex-shrink-0" style={`background-color: ${siteConfig.colors.accent}`}></span>
              <span class="text-sm" style="color: #94a3b8">Punto de equilibrio</span>
            </li>
            <li class="flex items-start">
              <span class="inline-block w-1.5 h-1.5 rounded-full mt-2 mr-3 flex-shrink-0" style={`background-color: ${siteConfig.colors.accent}`}></span>
              <span class="text-sm" style="color: #94a3b8">Margen real</span>
            </li>
            <li class="flex items-start">
              <span class="inline-block w-1.5 h-1.5 rounded-full mt-2 mr-3 flex-shrink-0" style={`background-color: ${siteConfig.colors.accent}`}></span>
              <span class="text-sm" style="color: #94a3b8">Claridad sobre cuánto puedes retirarte</span>
            </li>
          </ul>
        </div>

        <!-- Personal Sessions -->
        <div class="p-6 rounded-xl border" style={`background-color: ${siteConfig.colors.primary}; border-color: ${siteConfig.colors.primaryLight}`}>
          <h4 class="text-lg font-bold mb-4" style={`color: ${siteConfig.colors.accent}`}>3 sesiones personales</h4>
          <ul class="space-y-3">
            <li class="flex items-start">
              <span class="inline-block w-1.5 h-1.5 rounded-full mt-2 mr-3 flex-shrink-0" style={`background-color: ${siteConfig.colors.accent}`}></span>
              <span class="text-sm" style="color: #94a3b8">Separación empresa / persona</span>
            </li>
            <li class="flex items-start">
              <span class="inline-block w-1.5 h-1.5 rounded-full mt-2 mr-3 flex-shrink-0" style={`background-color: ${siteConfig.colors.accent}`}></span>
              <span class="text-sm" style="color: #94a3b8">Retiro mensual sostenible</span>
            </li>
            <li class="flex items-start">
              <span class="inline-block w-1.5 h-1.5 rounded-full mt-2 mr-3 flex-shrink-0" style={`background-color: ${siteConfig.colors.accent}`}></span>
              <span class="text-sm" style="color: #94a3b8">Orden financiero personal</span>
            </li>
            <li class="flex items-start">
              <span class="inline-block w-1.5 h-1.5 rounded-full mt-2 mr-3 flex-shrink-0" style={`background-color: ${siteConfig.colors.accent}`}></span>
              <span class="text-sm" style="color: #94a3b8">Metas claras</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Qué te llevas -->
    <div class="reveal mb-12">
      <h3 class="text-2xl sm:text-3xl font-bold text-center mb-6" style="color: #f1f5f9">
        Qué te llevas
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-lg mx-auto">
        <div class="flex items-start gap-3">
          <span style={`color: ${siteConfig.colors.accent}`}>&#x2714;</span>
          <span class="text-sm" style="color: #cbd5e1">Claridad real sobre cuánto ganas</span>
        </div>
        <div class="flex items-start gap-3">
          <span style={`color: ${siteConfig.colors.accent}`}>&#x2714;</span>
          <span class="text-sm" style="color: #cbd5e1">Decisiones basadas en números</span>
        </div>
        <div class="flex items-start gap-3">
          <span style={`color: ${siteConfig.colors.accent}`}>&#x2714;</span>
          <span class="text-sm" style="color: #cbd5e1">Menos improvisación</span>
        </div>
        <div class="flex items-start gap-3">
          <span style={`color: ${siteConfig.colors.accent}`}>&#x2714;</span>
          <span class="text-sm" style="color: #cbd5e1">Más tranquilidad financiera</span>
        </div>
      </div>
      <div class="text-center mt-8 space-y-1">
        <p class="text-base" style="color: #94a3b8">No prometo magia.</p>
        <p class="text-base font-semibold" style="color: #f1f5f9">Prometo estructura.</p>
      </div>
    </div>

    <!-- Inversión -->
    <div class="reveal mb-12">
      <h3 class="text-2xl sm:text-3xl font-bold text-center mb-6" style="color: #f1f5f9">
        ¿Es una inversión?
      </h3>
      <p class="text-center text-lg font-semibold mb-6" style="color: #f1f5f9">Sí.</p>
      <p class="text-center text-2xl font-bold mb-8" style={`color: ${siteConfig.colors.accent}`}>
        La inversión es USD 2,280.
      </p>
      <div class="text-center space-y-2 mb-8" style="color: #94a3b8">
        <p class="text-sm">Pero piensa en esto con honestidad:</p>
        <div class="space-y-1 mt-4">
          <p class="text-sm">Un mal cálculo de precios.</p>
          <p class="text-sm">Un préstamo mal tomado.</p>
          <p class="text-sm">Una expansión sin capital suficiente.</p>
          <p class="text-sm">Un año retirando dinero sin estructura.</p>
        </div>
        <p class="text-sm font-medium mt-4" style="color: #cbd5e1">Eso cuesta mucho más.</p>
      </div>
      <div class="text-center space-y-1">
        <p class="text-sm" style="color: #94a3b8">Esto no es un gasto.</p>
        <p class="text-base font-semibold" style="color: #f1f5f9">Es evitar errores costosos y ganar claridad.</p>
      </div>
    </div>

    <!-- CTA del programa -->
    <div class="reveal text-center">
      <h3 class="text-2xl sm:text-3xl font-bold mb-4" style="color: #f1f5f9">
        Si todo esto resonó contigo
      </h3>
      <p class="text-base mb-2" style="color: #94a3b8">
        Agenda una sesión estratégica gratuita de 30 minutos.
      </p>
      <p class="text-sm mb-8 max-w-lg mx-auto" style="color: #94a3b8">
        Es un espacio para entender tu situación actual y ver si este proceso tiene sentido para ti.<br><br>
        Sin presión.<br>
        Sin venta agresiva.<br>
        Con claridad.<br><br>
        Si encajamos, avanzamos.<br>
        Si no, al menos te llevas claridad.
      </p>
      <a
        href={`https://wa.me/${siteConfig.cta.whatsappNumber.replace(/\D/g, '')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-hover inline-flex items-center gap-3 px-8 py-4 rounded-full text-base font-semibold text-white"
        style={`background-color: ${siteConfig.colors.accent}`}
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Agenda tu sesión aquí
      </a>
    </div>

  </div>
</section>
